# ─── Supabase (required) ────────────────────────────────────────────────────
# These are the public anon credentials — safe to ship in a built client.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-jwt...

# ─── Razorpay (optional — enables online checkout) ─────────────────────────
# Public key id from the Razorpay dashboard (live or test). The matching
# RAZORPAY_KEY_SECRET lives only in Supabase function secrets, NOT here.
#
# When unset, the upgrade flow still renders but the "Continue to payment"
# button surfaces a friendly "online payments not yet enabled" message and
# customers can still reach Sales via the Enterprise WhatsApp path.
VITE_RAZORPAY_KEY_ID=

# ─── Sales (optional — enables Enterprise WhatsApp click-to-chat) ───────────
# Country code + number, digits only — e.g. 919876543210 for +91 98765 43210.
# When unset, the "Contact Sales" CTA on the Enterprise plan card falls back
# to an email alert (sales@vehiclesense.in).
VITE_SALES_WHATSAPP_NUMBER=

# ─── Supplier (us) identity for GST tax invoices ────────────────────────────
# These are set as Supabase function secrets, NOT VITE_ vars — they are read
# server-side by razorpay-webhook when issuing invoices and never reach the
# client. Listed here for documentation only.
#
#   supabase secrets set SUPPLIER_NAME='VehicleSense Technologies Pvt Ltd' \
#                        SUPPLIER_ADDRESS='Street, City, State, PIN' \
#                        SUPPLIER_STATE_CODE='33' \
#                        SUPPLIER_GSTIN='33ABCDE1234F1Z5'
#
# When SUPPLIER_GSTIN is unset the webhook still issues invoices (so the
# audit trail is complete from day one), but flags them is_dormant_supplier
# = true and skips the tax breakdown. Setting the env var later flips
# subsequent invoices to live tax computation; existing dormant rows stay
# as-is — they were never claimed against ITC.

# ─── Scheduled subscription reminders (Phase 1.7.1) ─────────────────────────
# These are also Supabase function secrets, NOT VITE_ vars. The
# subscription-reminders edge function reads them and the pg_cron schedule
# pings the function hourly via vault-stored URL + key.
#
# WhatsApp (preferred — 90%+ open rates in TN B2B). Reused from the
# whatsapp-alerts edge function — set both there and here.
#   supabase secrets set WHATSAPP_ACCESS_TOKEN='EAA…' \
#                        WHATSAPP_PHONE_NUMBER_ID='1234567890'
#
# Email fallback (when fleets.whatsapp_number is null). Resend is the
# default — easy DX, ~$20/mo for 50k messages, Deno-friendly.
#   supabase secrets set RESEND_API_KEY='re_…' \
#                        RESEND_FROM_EMAIL='noreply@vehiclesense.in'
#
# Cron wiring (one-time setup — read by the migration's pg_cron block):
#   supabase secrets set --vault \
#     SUPABASE_FUNCTIONS_URL_SUBSCRIPTION_REMINDERS='https://<ref>.functions.supabase.co/subscription-reminders' \
#     SUPABASE_ANON_KEY_FOR_CRON='<anon-key>'
#
# Public app URL used in reminder copy (the "Manage subscription" link).
# Defaults to https://app.vehiclesense.in if unset.
#   supabase secrets set APP_URL='https://app.vehiclesense.in'
#
# When any channel's secrets are unset the function logs and skips that
# channel without erroring. Dormant-mode safe: the cron schedule installs
# regardless and starts firing real reminders the moment secrets land.
