<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Theme applied to the Android Window while the process is starting (splash screen) -->
    <style name="LaunchTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <!-- Background for splash screen -->
        <item name="android:windowBackground">@drawable/launch_background</item>
    </style>

    <!-- Normal theme applied once Flutter engine starts -->
    <style name="NormalTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/flutter_window_background</item>
    </style>
</resources>